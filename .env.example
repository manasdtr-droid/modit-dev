# Public WhatsApp Business number in international format, digits only.
# Example: 919876543210
MODIT_WHATSAPP_PHONE=

# Lead destination webhook. Can be Google Apps Script, Make, Zapier, Airtable automation,
# or a custom CRM endpoint that accepts JSON POST requests.
LEADS_WEBHOOK_URL=
LEADS_WEBHOOK_SECRET=
LEADS_WEBHOOK_LABEL=MODIT lead webhook
LEADS_WEBHOOK_TIMEOUT_MS=8000

# Local development only. Set to 0 to disable .tmp/leads.jsonl logging.
LEADS_LOCAL_LOG=1
